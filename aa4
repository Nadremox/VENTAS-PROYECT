    if len(opcionesClientes) > 0:
        cboClienteVenta.current(0)

    lblTotal = tk.Label(panel, text="Total General: S/ 0.00", fg="green", font=("Arial", 12, "bold"))
    lblTotal.place(x=650, y=520)

    # Tabla de productos registrados
    tk.Label(panel, text="PRODUCTOS REGISTRADOS", fg="green", font=("Arial", 11, "bold")).place(x=60, y=140)

    columnasProductos = ("Codigo", "Nombre", "Precio", "Stock")
    tablaProductosVenta = ttk.Treeview(panel, columns=columnasProductos, show="headings", height=6)

    for col in columnasProductos:
        tablaProductosVenta.heading(col, text=col)

    tablaProductosVenta.column("Codigo", width=100)
    tablaProductosVenta.column("Nombre", width=220)
    tablaProductosVenta.column("Precio", width=120)
    tablaProductosVenta.column("Stock", width=100)
    tablaProductosVenta.place(x=60, y=170)

    # Tabla de ventas realizadas
    tk.Label(panel, text="VENTAS REGISTRADAS", fg="blue", font=("Arial", 11, "bold")).place(x=60, y=330)

    columnasVentas = ("Codigo", "Producto", "Cliente", "Precio", "Cantidad", "Subtotal")
    tablaRegistroVentas = ttk.Treeview(panel, columns=columnasVentas, show="headings", height=6)

    for col in columnasVentas:
        tablaRegistroVentas.heading(col, text=col)

    tablaRegistroVentas.column("Codigo", width=90)
    tablaRegistroVentas.column("Producto", width=180)
    tablaRegistroVentas.column("Cliente", width=180)
    tablaRegistroVentas.column("Precio", width=100)
    tablaRegistroVentas.column("Cantidad", width=90)
    tablaRegistroVentas.column("Subtotal", width=120)
    tablaRegistroVentas.place(x=60, y=360)

    def actualizarTablaProductosVenta():
        for item in tablaProductosVenta.get_children():
            tablaProductosVenta.delete(item)

        for producto in productos:
            tablaProductosVenta.insert(
                "",
                "end",
                values=(producto.codigo, producto.nombre, producto.precio, producto.stock)
            )

    def actualizarTablaRegistroVentas():
        for item in tablaRegistroVentas.get_children():
            tablaRegistroVentas.delete(item)

        total = 0

        for venta in ventas:
            tablaRegistroVentas.insert(
                "",
                "end",
                values=(venta.codigo, venta.producto, venta.cliente, venta.precio, venta.cantidad, venta.subtotal)
            )
            total += venta.subtotal

        lblTotal.config(text=f"Total General: S/ {total:.2f}")

    def seleccionarProducto(event):
        seleccionado = tablaProductosVenta.selection()
        if seleccionado:
            datos = tablaProductosVenta.item(seleccionado)["values"]
            txtCodVenta.delete(0, tk.END)
            txtCodVenta.insert(0, datos[0])

            txtPrecioVenta.delete(0, tk.END)
            txtPrecioVenta.insert(0, datos[2])

    tablaProductosVenta.bind("<<TreeviewSelect>>", seleccionarProducto)

    def vender():
        codigo = txtCodVenta.get()
        precio = txtPrecioVenta.get()
        cantidad = txtCantidad.get()
        clienteSeleccionado = cboClienteVenta.get()

        if codigo == "" or precio == "" or cantidad == "" or clienteSeleccionado == "":
            messagebox.showerror("Error", "Complete todos los campos")
            return

        nombreCliente = clienteSeleccionado.split(" - ", 1)[1]

        try:
            precio = float(precio)
            cantidad = int(cantidad)
            encontrado = False

            for producto in productos:
                if str(producto.codigo) == codigo:
                    if cantidad > producto.stock:
                        messagebox.showerror("Error", "Stock insuficiente")
                    else:
                        subtotal = precio * cantidad

                        venta = Venta(
                            producto.codigo,
                            producto.nombre,
                            nombreCliente,
                            precio,
                            cantidad,
                            subtotal
                        )
                        ventas.append(venta)

                        producto.stock = producto.stock - cantidad

                        actualizarTablaProductosVenta()
                        actualizarTablaRegistroVentas()

                        messagebox.showinfo("Venta", "Venta registrada correctamente")

                        txtCodVenta.delete(0, tk.END)
                        txtPrecioVenta.delete(0, tk.END)
                        txtCantidad.delete(0, tk.END)
                        if len(opcionesClientes) > 0:
                            cboClienteVenta.current(0)

                    encontrado = True
                    break

            if encontrado == False:
                messagebox.showerror("Error", "Producto no encontrado")

        except:
            messagebox.showerror("Error", "Precio o cantidad inválidos")

    def limpiarVenta():
        txtCodVenta.delete(0, tk.END)
        txtPrecioVenta.delete(0, tk.END)
        txtCantidad.delete(0, tk.END)
        if len(opcionesClientes) > 0:
            cboClienteVenta.current(0)
        txtCodVenta.focus()

    tk.Button(panel, text="REALIZAR VENTA", width=20, command=vender).place(x=700, y=67)
    tk.Button(panel, text="LIMPIAR", width=15, command=limpiarVenta).place(x=700, y=105)

    actualizarTablaProductosVenta()
    actualizarTablaRegistroVentas()


