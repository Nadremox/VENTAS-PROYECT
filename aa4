# ====================================
# CLASES
# ====================================
class Producto:

    def __init__(self, codigo, nombre, precio, stock):
        self.codigo = codigo
        self.nombre = nombre
        self.precio = precio
        self.stock = stock

    def obtenerResultados(self):
        return f"Código : {self.codigo} | Nombre : {self.nombre} | Precio : {self.precio} | Stock : {self.stock}"


class Cliente:

    def __init__(self, dni, nombre, telefono):
        self.dni = dni
        self.nombre = nombre
        self.telefono = telefono

    def obtenerResultados(self):
        return f"DNI : {self.dni} | Nombre : {self.nombre} | Teléfono : {self.telefono}"


class Venta:

    def __init__(self, codigo, producto, cliente, precio, cantidad, subtotal):
        self.codigo = codigo
        self.producto = producto
        self.cliente = cliente
        self.precio = precio
        self.cantidad = cantidad
        self.subtotal = subtotal

    def obtenerResultados(self):
        return f"Código : {self.codigo} | Producto : {self.producto} | Cliente : {self.cliente} | Precio : {self.precio} | Cantidad : {self.cantidad} | Subtotal : {self.subtotal}"


