            lblDatos.config(text="CLIENTE ENCONTRADO")
            clientesFiltrados = []
            for cliente in clientes:
                if cliente.nombre == clienteBuscado:
                    clientesFiltrados.append(cliente)

            ventasFiltradas = []
            for venta in ventas:
                if venta.cliente == clienteBuscado:
                    ventasFiltradas.append(venta)

        for cliente in clientesFiltrados:
            tablaDatos.insert(
                "",
                "end",
                values=(
                    "Cliente",
                    cliente.nombre,
                    cliente.dni,
                    cliente.telefono
