                    venta.producto,
                    venta.cliente,
                    f"S/ {venta.precio:.2f}",
                    venta.cantidad,
                    f"S/ {venta.subtotal:.2f}"
                )
            )
            totalVentas += venta.subtotal
            cantidadVentas += 1

        if clienteBuscado == "":
            lblResumen.config(
                text=f"Productos: {len(productos)}   Clientes: {len(clientes)}   Ventas: {len(ventas)}   Total vendido: S/ {totalVentas:.2f}"
            )
        else:
            lblResumen.config(
                text=f"Cliente: {clienteBuscado}   Ventas: {cantidadVentas}   Total vendido: S/ {totalVentas:.2f}"
            )

        lblTotalReporte.config(text=f"TOTAL GENERAL DE VENTAS: S/ {totalVentas:.2f}")

    def buscarCliente():
        clienteBuscado = cboBuscarCliente.get()
        if clienteBuscado == "":
            messagebox.showerror("Error", "Seleccione un cliente")
            return
        cargarReporte(clienteBuscado)

    def mostrarTodos():
        cboBuscarCliente.set("")
        cargarReporte()

    tk.Button(panel, text="BUSCAR", width=12, command=buscarCliente).place(x=390, y=47)
    tk.Button(panel, text="MOSTRAR TODOS", width=15, command=mostrarTodos).place(x=500, y=47)

    cargarReporte()


