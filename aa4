def actualizarTablaProductos():
    for item in tabla.get_children():
        tabla.delete(item)

    for producto in productos:
        tabla.insert(
            "",
            "end",
            values=(
                producto.codigo,
                producto.nombre,
                producto.precio,
                producto.stock
            )
        )

    txtNombre.focus()


def limpiarCampos():
    txtCodigo.delete(0, tk.END)
    txtNombre.set("")
    txtPrecio.delete(0, tk.END)
    txtStock.delete(0, tk.END)


def agregar():
    codigo = txtCodigo.get()
    nombre = txtNombre.get()
    precio = txtPrecio.get()
    stock = txtStock.get()

    if nombre == "" or precio == "" or stock == "":
        messagebox.showerror("Error", "Complete todos los campos")
        return

    if not validarNombre(nombre):
        messagebox.showerror("Error", "Nombre inválido")
        return

    try:
        precio = float(precio)
        stock = int(stock)

        producto = Producto(codigo, nombre, precio, stock)
        productos.append(producto)

        actualizarTablaProductos()

        lstSalida.insert(
            0,
            f"Producto {nombre} registrado correctamente"
        )

        limpiarCampos()
        txtCodigo.insert(0, generarCodigo())

    except:
        messagebox.showerror("Error", "Precio o stock inválidos")


def eliminar():
    seleccionado = tabla.selection()

    if seleccionado:
        indice = tabla.index(seleccionado)
        productos.pop(indice)
        actualizarTablaProductos()


def editar():
    seleccionado = tabla.selection()

    if not seleccionado:
        return

    datos = tabla.item(seleccionado)["values"]

    limpiarCampos()
    txtCodigo.insert(0, datos[0])
    txtNombre.set(datos[1])
    txtPrecio.insert(0, datos[2])
    txtStock.insert(0, datos[3])


def modificar():
    seleccionado = tabla.selection()

    if not seleccionado:
        return

    codigo = txtCodigo.get()
    nombre = txtNombre.get()
    precio = txtPrecio.get()
    stock = txtStock.get()

    if nombre == "" or precio == "" or stock == "":
        messagebox.showerror("Error", "Complete todos los campos")
        return

    if not validarNombre(nombre):
        messagebox.showerror("Error", "Nombre inválido")
        return

    try:
        precio = float(precio)
        stock = int(stock)
        indice = tabla.index(seleccionado)

        productos[indice].codigo = codigo
        productos[indice].nombre = nombre
        productos[indice].precio = precio
        productos[indice].stock = stock

        actualizarTablaProductos()
        lstSalida.insert(0, f"Producto {nombre} modificado correctamente")
        limpiarCampos()
        txtCodigo.insert(0, generarCodigo())

